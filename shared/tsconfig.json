{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/types": ["./types"],
      "@shared/types/*": ["./types/*"]
    }
  },
  "include": ["types/**/*"],
  "exclude": ["node_modules", "dist"]
}
