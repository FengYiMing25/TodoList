{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/types": ["./shared/types"],
      "@shared/types/*": ["./shared/types/*"]
    }
  },
  "include": ["shared/**/*"],
  "exclude": ["node_modules", "dist", "client", "server"]
}
